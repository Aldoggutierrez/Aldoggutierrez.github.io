---
import { site } from '../data/site';
---

<section id="contacto">
  <div class="container">
    <p class="eyebrow"><span class="n">05</span> — CONTACTO</p>
    <div class="contact-box">
      <div>
        <p class="contact-h">¿Construimos algo<br><span class="dim">que escale?</span></p>
      </div>
      <div class="contact-links">
        <a class="cl" href={`mailto:${site.email}`}>{site.email}</a>
        <a class="cl" href={site.github}  target="_blank">{site.github.replace('https://', '')}</a>
        <a class="cl" href={site.linkedin} target="_blank">{site.linkedin.replace('https://', '')}</a>
        <a class="cl" href={site.cvUrl}>Descargar CV →</a>
      </div>
    </div>
  </div>
</section>

<style>
  section {
    padding: 5rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 2.5rem;
  }

  .eyebrow {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: #444441;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    margin-bottom: 2.5rem;
  }
  .eyebrow .n { color: #378ADD; }

  .contact-box {
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 10px;
    padding: 3rem 2.5rem;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: center;
  }

  .contact-h {
    font-family: 'Syne', sans-serif;
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }
  .contact-h .dim { color: #444441; }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-end;
  }

  .cl {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: #888780;
    text-decoration: none;
    letter-spacing: 0.04em;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }
  .cl:hover {
    color: #f0ede8;
    border-color: rgba(255, 255, 255, 0.3);
  }

  @media (max-width: 700px) {
    .contact-box   { grid-template-columns: 1fr; }
    .contact-links { align-items: flex-start; }
  }
</style>
