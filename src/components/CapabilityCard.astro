---
import type { Capability } from '../data/capabilities';

interface Props {
  capability: Capability;
}
const { capability } = Astro.props;
---

<div class="cap-card">
  <p class="cap-icon">{capability.icon}</p>
  <p class="cap-name">{capability.name}</p>
  <p class="cap-desc">{capability.desc}</p>
  <div class="cap-pills">
    {capability.pills.map(pill => (
      <span class="cpill">{pill}</span>
    ))}
  </div>
</div>

<style>
  .cap-card {
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 8px;
    padding: 1.35rem 1.25rem 1.1rem;
    transition: border-color 0.2s, background 0.2s;
  }
  .cap-card:hover {
    border-color: rgba(55, 138, 221, 0.35);
    background: #111111;
  }

  .cap-icon {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    color: #378ADD;
    margin-bottom: 0.75rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .cap-name {
    font-family: 'Syne', sans-serif;
    font-size: 14px;
    font-weight: 700;
    margin-bottom: 0.45rem;
  }

  .cap-desc {
    font-size: 12px;
    color: #888780;
    line-height: 1.65;
  }

  .cap-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 0.75rem;
  }

  .cpill {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    padding: 2px 7px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 2px;
    color: #444441;
  }
</style>
