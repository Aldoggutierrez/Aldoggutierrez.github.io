---
import '../styles/global.css';
import Cursor from '../components/Cursor.astro';

interface Props {
  title?: string;
}
const { title = 'Aldo Gutierrez — Fullstack Engineer & DevOps' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Portafolio de Aldo Gutierrez — Fullstack Engineer & DevOps especializado en Laravel, Vue 3, Docker y GDS." />
    <title>{title}</title>

    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Space+Mono:wght@400;700&family=Instrument+Sans:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Cursor />
    <slot />
  </body>
</html>
